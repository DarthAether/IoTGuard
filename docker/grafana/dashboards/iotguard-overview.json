      "title": "Analysis Latency",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(iotguard_analysis_latency_seconds_bucket[5m])) by (le, engine))", "legendFormat": "p50 {{ engine }}", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(iotguard_analysis_latency_seconds_bucket[5m])) by (le, engine))", "legendFormat": "p95 {{ engine }}", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(iotguard_analysis_latency_seconds_bucket[5m])) by (le, engine))", "legendFormat": "p99 {{ engine }}", "refId": "C" }
      ]
    },
