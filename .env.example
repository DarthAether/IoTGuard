# =============================================================================
# IoTGuard Configuration
# Copy to .env and fill in values for your environment.
# =============================================================================

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_CORS_ORIGINS=["http://localhost:3000"]
API_TITLE=IoTGuard
API_VERSION=1.0.0

# --- JWT ---
JWT_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=iotguard
DB_PASSWORD=iotguard
DB_NAME=iotguard
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_KEY_PREFIX=iotguard:

# --- Google Gemini ---
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL_NAME=gemini-1.5-flash
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_TOKENS=2048

# --- MQTT Broker ---
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=iotguard
MQTT_PASSWORD=iotguard
MQTT_CLIENT_ID=iotguard-server
MQTT_TOPICS=["iotguard/devices/#","iotguard/commands/#","iotguard/status/#"]

# --- Device Defaults ---
DEVICE_DEFAULT_DEVICES=["door_lock_01","camera_01","speaker_01","thermostat_01","light_01"]

# --- Alerts ---
ALERT_HIGH_RISK_THRESHOLD=HIGH
ALERT_BLOCK_ON_CRITICAL=true

# --- Observability ---
OBSERVABILITY_PROMETHEUS_ENABLED=true
OBSERVABILITY_AUDIT_ENABLED=true
OBSERVABILITY_LOG_LEVEL=INFO
OBSERVABILITY_LOG_FORMAT=json
